  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/reports/daily-email",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/reports/subscription-reminders",
      "schedule": "0 3 * * *"
    }
  ]
}
